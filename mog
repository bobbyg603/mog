#!/usr/bin/env bash
set -euo pipefail

# ============================================================================
# mog - Sandboxed Claude Issue Mogging
# Fetches a GitHub issue, creates a worktree, runs Claude Code in a persistent
# Docker sandbox, then opens a PR.
#
# Usage:
#   mog init                      — one-time setup: create sandbox & login
#   mog <owner/repo> <issue_num>  — fetch issue, run Claude, open PR
#
# Example:
#   mog init
#   mog workingdevshero/automate-it 123
# ============================================================================

SANDBOX_NAME="mog"

# ---------------------------------------------------------------------------
# Colors & helpers
# ---------------------------------------------------------------------------
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
NC='\033[0m' # No Color

info()  { echo -e "${CYAN}[mog]${NC} $*"; }
ok()    { echo -e "${GREEN}[mog]${NC} $*"; }
warn()  { echo -e "${YELLOW}[mog]${NC} $*"; }
err()   { echo -e "${RED}[mog]${NC} $*" >&2; }
die()   { err "$@"; exit 1; }

# ---------------------------------------------------------------------------
# Validate dependencies
# ---------------------------------------------------------------------------
for cmd in gh git docker jq; do
  command -v "$cmd" &>/dev/null || die "Required command not found: $cmd"
done

if ! docker sandbox ls &>/dev/null 2>&1; then
  die "Docker sandbox not available. Make sure Docker Desktop is running and up to date."
fi

# ---------------------------------------------------------------------------
# Repos directory — this is the sandbox workspace root
# ---------------------------------------------------------------------------
REPOS_DIR="${MOG_REPOS_DIR:-$HOME/mog-repos}"
mkdir -p "$REPOS_DIR"

# ---------------------------------------------------------------------------
# mog init — create persistent sandbox & authenticate
# ---------------------------------------------------------------------------
if [[ "${1:-}" == "init" ]]; then
  info "Initializing mog sandbox..."

  # Check if sandbox already exists
  if docker sandbox ls 2>/dev/null | grep -q "$SANDBOX_NAME"; then
    warn "Sandbox '${SANDBOX_NAME}' already exists."
    info "Launching sandbox so you can authenticate with /login..."
    docker sandbox run "$SANDBOX_NAME"
  else
    info "Creating persistent sandbox '${SANDBOX_NAME}'..."
    info "Workspace: ${REPOS_DIR}"
    docker sandbox create --name "$SANDBOX_NAME" claude "$REPOS_DIR"
    ok "Sandbox created."
    echo ""
    info "Launching sandbox — authenticate with /login to use your Max subscription."
    info "Once logged in, type /exit or Ctrl+C to return."
    echo ""
    docker sandbox run "$SANDBOX_NAME"
  fi

  ok "mog is ready. Run: mog <owner/repo> <issue_number>"
  exit 0
fi

# ---------------------------------------------------------------------------
# Parse arguments
# ---------------------------------------------------------------------------
if [[ $# -lt 2 ]]; then
  echo "Usage:"
  echo "  mog init                      — one-time setup (create sandbox & login)"
  echo "  mog <owner/repo> <issue_num>  — fetch issue, run Claude, open PR"
  echo ""
  echo "Example:"
  echo "  mog init"
  echo "  mog workingdevshero/automate-it 123"
  exit 1
fi

REPO="$1"
ISSUE_NUM="$2"
OWNER="${REPO%%/*}"
REPO_NAME="${REPO##*/}"

# ---------------------------------------------------------------------------
# Verify sandbox exists
# ---------------------------------------------------------------------------
if ! docker sandbox ls 2>/dev/null | grep -q "$SANDBOX_NAME"; then
  die "Sandbox '${SANDBOX_NAME}' not found. Run 'mog init' first."
fi

# ---------------------------------------------------------------------------
# Fetch issue details via GitHub CLI (on host)
# ---------------------------------------------------------------------------
info "Fetching issue #${ISSUE_NUM} from ${REPO}..."

ISSUE_JSON=$(gh issue view "$ISSUE_NUM" \
  --repo "$REPO" \
  --json title,body,labels,assignees \
  2>/dev/null) \
  || die "Failed to fetch issue #${ISSUE_NUM}. Check repo name and issue number."

ISSUE_TITLE=$(echo "$ISSUE_JSON" | jq -r '.title')
ISSUE_BODY=$(echo "$ISSUE_JSON" | jq -r '.body // "No description provided."')
ISSUE_LABELS=$(echo "$ISSUE_JSON" | jq -r '[.labels[].name] | join(", ") // "none"')

ok "Issue: ${ISSUE_TITLE}"

# ---------------------------------------------------------------------------
# Ensure local repo exists & get default branch
# ---------------------------------------------------------------------------
REPO_DIR="$REPOS_DIR/$OWNER/$REPO_NAME"

if [[ ! -d "$REPO_DIR" ]]; then
  info "Cloning ${REPO} into ${REPO_DIR}..."
  mkdir -p "$REPOS_DIR/$OWNER"
  gh repo clone "$REPO" "$REPO_DIR"
fi

DEFAULT_BRANCH=$(gh repo view "$REPO" --json defaultBranchRef --jq '.defaultBranchRef.name')
info "Default branch: ${DEFAULT_BRANCH}"

# ---------------------------------------------------------------------------
# Create a sanitized branch name from the issue
# ---------------------------------------------------------------------------
SAFE_TITLE=$(echo "$ISSUE_TITLE" \
  | tr '[:upper:]' '[:lower:]' \
  | sed 's/[^a-z0-9]/-/g' \
  | sed 's/--*/-/g' \
  | sed 's/^-//;s/-$//' \
  | cut -c1-50)
BRANCH_NAME="${ISSUE_NUM}-${SAFE_TITLE}"

# ---------------------------------------------------------------------------
# Create worktree
# ---------------------------------------------------------------------------
WORKTREE_DIR="$REPOS_DIR/$OWNER/${REPO_NAME}-worktrees/${BRANCH_NAME}"

if [[ -d "$WORKTREE_DIR" ]]; then
  warn "Worktree already exists at ${WORKTREE_DIR}, reusing."
else
  info "Creating worktree for branch '${BRANCH_NAME}'..."
  cd "$REPO_DIR"

  git fetch origin "$DEFAULT_BRANCH" 2>/dev/null || true

  git worktree add -b "$BRANCH_NAME" "$WORKTREE_DIR" "origin/${DEFAULT_BRANCH}" 2>/dev/null \
    || git worktree add "$WORKTREE_DIR" "$BRANCH_NAME" 2>/dev/null \
    || die "Failed to create worktree. Branch '${BRANCH_NAME}' may already exist."

  ok "Worktree created at ${WORKTREE_DIR}"
fi

# ---------------------------------------------------------------------------
# Build the prompt for Claude Code
# ---------------------------------------------------------------------------
PROMPT_FILE=$(mktemp)
trap 'rm -f "$PROMPT_FILE"' EXIT

cat > "$PROMPT_FILE" <<PROMPT_EOF
You are working on GitHub issue #${ISSUE_NUM} for the repository ${REPO}.

## Issue: ${ISSUE_TITLE}

### Description
${ISSUE_BODY}

### Labels
${ISSUE_LABELS}

## Instructions
1. Read and understand the codebase structure first.
2. Implement the changes described in the issue above.
3. Write clean, well-documented code that follows the existing project conventions.
4. Add or update tests if applicable.
5. Make sure the code builds/lints without errors if there's a build system.
6. Commit your changes with a clear commit message referencing issue #${ISSUE_NUM}.

When you are done, make a single commit (or a small, logical set of commits) with
a message like: "fix: <short description> (#${ISSUE_NUM})"
PROMPT_EOF

PROMPT=$(cat "$PROMPT_FILE")

# ---------------------------------------------------------------------------
# Run Claude Code in the persistent sandbox
# ---------------------------------------------------------------------------
info "Launching Claude Code in sandbox..."
info "Branch: ${BRANCH_NAME}"
info "Worktree: ${WORKTREE_DIR}"
echo ""

# The worktree lives under REPOS_DIR which is the sandbox workspace.
# Use stream-json output so we can display progress in real-time.
docker sandbox exec -w "$WORKTREE_DIR" "$SANDBOX_NAME" \
  claude --dangerously-skip-permissions --verbose --output-format stream-json -p "$PROMPT" 2>/dev/null | \
  jq --unbuffered -r '
    if .type == "assistant" and .message.content then
      .message.content[] |
        if .type == "text" then
          .text
        elif .type == "tool_use" then
          "\u001b[0;36m[" + .name + "]\u001b[0m " + (
            if .name == "Read" then (.input.file_path // "")
            elif .name == "Edit" then (.input.file_path // "")
            elif .name == "Write" then (.input.file_path // "")
            elif .name == "Bash" then (.input.description // .input.command // "")
            elif .name == "Glob" then (.input.pattern // "")
            elif .name == "Grep" then (.input.pattern // "")
            else (.input | tostring | .[0:120])
            end
          )
        else empty
        end
    elif .type == "result" then
      if .is_error then
        "\u001b[0;31m[error]\u001b[0m " + (.result // "unknown error")
      else
        "\n\u001b[0;32m[done]\u001b[0m " + (.result // "" | .[0:200])
      end
    else empty
    end
  '

CLAUDE_EXIT=${PIPESTATUS[0]}

if [[ $CLAUDE_EXIT -ne 0 ]]; then
  warn "Claude Code exited with code ${CLAUDE_EXIT}."
  warn "The worktree is still available at: ${WORKTREE_DIR}"
  warn "You can re-run manually or inspect the changes."
fi

# ---------------------------------------------------------------------------
# Check if there are changes to commit / push
# ---------------------------------------------------------------------------
cd "$WORKTREE_DIR"

# Check for unpushed commits OR uncommitted changes
HAS_UNPUSHED=$(git log "origin/${DEFAULT_BRANCH}..HEAD" --oneline 2>/dev/null | head -1)
HAS_UNCOMMITTED=false
if ! git diff --quiet || ! git diff --cached --quiet; then
  HAS_UNCOMMITTED=true
fi

if [[ -z "$HAS_UNPUSHED" ]] && [[ "$HAS_UNCOMMITTED" == "false" ]]; then
  warn "No changes detected. Claude may not have made any modifications."
  warn "Worktree: ${WORKTREE_DIR}"
  exit 0
fi

# Stage any unstaged changes Claude might have left
if [[ "$HAS_UNCOMMITTED" == "true" ]]; then
  info "Staging uncommitted changes..."
  git add -A
  git commit -m "fix: address issue #${ISSUE_NUM} - ${ISSUE_TITLE}" || true
fi

# ---------------------------------------------------------------------------
# Push and open PR (on host, using host's gh credentials)
# ---------------------------------------------------------------------------
info "Pushing branch '${BRANCH_NAME}' to origin..."
git push -u origin "$BRANCH_NAME" \
  || die "Failed to push. Check your git credentials."

ok "Branch pushed."

info "Opening pull request..."

PR_BODY_FILE=$(mktemp)
cat > "$PR_BODY_FILE" <<PR_EOF
## Summary

Closes #${ISSUE_NUM}

This PR was generated by [mog](https://github.com/workingdevshero/mog) using Claude Code in a Docker sandbox.

### Issue: ${ISSUE_TITLE}

${ISSUE_BODY}

---
*Please review the changes carefully before merging.*
PR_EOF

PR_TITLE="fix: ${ISSUE_TITLE} [#${ISSUE_NUM}]"

PR_URL=$(gh pr create \
  --repo "$REPO" \
  --base "$DEFAULT_BRANCH" \
  --head "$BRANCH_NAME" \
  --title "$PR_TITLE" \
  --body-file "$PR_BODY_FILE" \
  2>&1) \
  || die "Failed to create PR. You may need to push first or the PR may already exist."

rm -f "$PR_BODY_FILE"

ok "Pull request created!"
echo -e "${GREEN}${PR_URL}${NC}"

# ---------------------------------------------------------------------------
# Done
# ---------------------------------------------------------------------------
echo ""
ok "All done! Issue #${ISSUE_NUM} → Branch '${BRANCH_NAME}' → PR opened."
info "Worktree: ${WORKTREE_DIR}"
info "To clean up the worktree later: git worktree remove ${WORKTREE_DIR}"
